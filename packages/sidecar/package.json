{
  "name": "a2ui-inspector",
  "version": "0.0.0",
  "type": "module",
  "main": "dist/server.js",
  "bin": { "a2ui-inspector": "dist/bin.js" },
  "files": ["dist", "ui-dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/bin.ts",
    "start": "node dist/bin.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint: noop'",
    "prepublishOnly": "node -e \"import('node:fs').then(fs => { fs.cpSync('../ui/dist', 'ui-dist', { recursive: true }); })\""
  },
  "dependencies": {
    "@a2ui-inspector/shared": "workspace:*",
    "@fastify/static": "^7.0.0",
    "@fastify/websocket": "^10.0.0",
    "fastify": "^4.26.0",
    "ws": "^8.17.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
